{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Game",
            "type": "shell",
            "command": "cmake -B build_ninja -G Ninja -DCMAKE_BUILD_TYPE=Debug && cmake --build build_ninja -j$(nproc)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Tests (Catch2)",
            "type": "shell",
            "command": "cmake -B build_ninja -G Ninja -DCMAKE_BUILD_TYPE=Debug && cmake --build build_ninja -j$(nproc) --target test_target && ./build_ninja/test_target",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Server",
            "type": "shell",
            "command": "./build_ninja/match_backend",
            "dependsOn": "Build Game",
            "problemMatcher": []
        }
    ]
}