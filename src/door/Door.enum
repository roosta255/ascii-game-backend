DOOR_DECL(ELEVATOR_OPEN_KEYLESS,            false,        iActivator,            iActivator,  true, true)
DOOR_DECL(ELEVATOR_OPEN_KEYLESS_BUTTON,     false,        iActivator,     ActivatorElevator,  true, true)
