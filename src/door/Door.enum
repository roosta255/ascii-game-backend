DOOR_DECL(ELEVATOR_CLOSED_KEYLESS_BUTTON,    true,        iActivator,     ActivatorElevator,  true, true)
DOOR_DECL(ELEVATOR_CLOSED_CALL_BUTTON,       true,        iActivator,     ActivatorElevator,  true, true)
DOOR_DECL(ELEVATOR_OPEN_KEYED,              false,        iActivator,            iActivator,  true, true)
DOOR_DECL(ELEVATOR_OPEN_KEYED_PAYING_BUTTON, false,       iActivator,     ActivatorElevator,  true, true)
DOOR_DECL(ELEVATOR_OPEN_KEYED_MOVING_BUTTON, false,       iActivator,     ActivatorElevator,  true, true)
