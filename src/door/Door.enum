DOOR_DECL(SHIFTER_EGRESS_KEYLESS,            true,        iActivator,            iActivator,  true, true)
DOOR_DECL(SHIFTER_INGRESS_KEYED,            false,        iActivator,            iActivator,  true, true)
DOOR_DECL(SHIFTER_INGRESS_KEYLESS,           true,        iActivator,            iActivator,  true, true)
    DOOR_LOCK_WRAPPER({
        .effects = { ActivatorBounceLock{}, ActivatorValidateNotOccupied{}, ActivatorSetSharedDoors{DOOR_SHIFTER_INGRESS_KEYED, DOOR_SHIFTER_EGRESS_KEYED, ANIMATION_SLIDE, {EVENT_UNLOCK, {}, {EventComponentKind::ITEM, ITEM_KEY}}} },
        .required = makeTraitBits({TRAIT_ACTOR, TRAIT_KEYER, TRAIT_ACTION_READY}),
        .itemCost = { ITEM_KEY },
        .actionCost = 1
    })
// dungeons start orange: open, blue: closed
DOOR_DECL(TOGGLER_ORANGE_CLOSED,             true,        iActivator,            iActivator,  true, true)
DOOR_DECL(TOGGLER_ORANGE_OPEN,              false,        iActivator,            iActivator,  true, true)
DOOR_DECL(TOGGLER_BLUE_CLOSED,               true,        iActivator,            iActivator,  true, true)
DOOR_DECL(TOGGLER_BLUE_OPEN,                false,        iActivator,            iActivator,  true, true)
// lightning rod
DOOR_DECL(LIGHTNING_ROD_AWAKENED,           false,        iActivator, ActivatorLightningRod, false, false)
DOOR_DECL(LIGHTNING_ROD_DORMANT,            false,        iActivator, ActivatorLightningRod, false, false)
DOOR_DECL(LIGHTNING_ROD_EMPTY,              false,        iActivator, ActivatorLightningRod, false, false)
