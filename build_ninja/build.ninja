# Utility command for test

build extern/Catch2/src/CMakeFiles/test.util: CUSTOM_COMMAND
  COMMAND = cd /workspaces/backend/build_ninja/extern/Catch2/src && /usr/bin/ctest --force-new-ctest-process
  DESC = Running tests...
  pool = console
  restat = 1

build extern/Catch2/src/test: phony extern/Catch2/src/CMakeFiles/test.util


#############################################
# Utility command for edit_cache

build extern/Catch2/src/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = cd /workspaces/backend/build_ninja/extern/Catch2/src && /usr/bin/cmake -E echo No\ interactive\ CMake\ dialog\ available.
  DESC = No interactive CMake dialog available...
  restat = 1

build extern/Catch2/src/edit_cache: phony extern/Catch2/src/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build extern/Catch2/src/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = cd /workspaces/backend/build_ninja/extern/Catch2/src && /usr/bin/cmake --regenerate-during-build -S/workspaces/backend -B/workspaces/backend/build_ninja
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build extern/Catch2/src/rebuild_cache: phony extern/Catch2/src/CMakeFiles/rebuild_cache.util

