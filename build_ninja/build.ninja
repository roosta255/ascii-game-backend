# Target aliases.

build Catch2: phony extern/Catch2/src/libCatch2d.a

build Catch2WithMain: phony extern/Catch2/src/libCatch2Maind.a

build core_backend: phony libcore_backend.a

build libCatch2Maind.a: phony extern/Catch2/src/libCatch2Maind.a

build libCatch2d.a: phony extern/Catch2/src/libCatch2d.a

# =============================================================================
# Folder targets.

# =============================================================================

#############################################
# Folder: /workspaces/backend/build_ninja

build all: phony libcore_backend.a match_backend test_target extern/Catch2/all

# =============================================================================

#############################################
# Folder: /workspaces/backend/build_ninja/extern/Catch2

build extern/Catch2/all: phony extern/Catch2/src/all

# =============================================================================

#############################################
# Folder: /workspaces/backend/build_ninja/extern/Catch2/src

build extern/Catch2/src/all: phony extern/Catch2/src/libCatch2d.a extern/Catch2/src/libCatch2Maind.a

