{
  "name": "ascii-backend",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },

  "workspaceFolder": "/workspaces/backend",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/backend,type=bind",

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },

  "remoteEnv": {
    "SHELL": "/bin/bash",
    "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
    "HOST_PROJECT_PATH": "${localWorkspaceFolder}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "continue.continue",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "remote.extensionKind": {
          "continue.continue": ["workspace"]
        }
      }
    }
  },

  "runArgs": [
    "--network=backend_default"
  ],

  "postCreateCommand": "mkdir -p /root/.continue && printf '{\n  \"models\": [{\n    \"title\": \"Claude\",\n    \"provider\": \"anthropic\",\n    \"model\": \"claude-3-5-sonnet\",\n    \"apiKey\": \"'$ANTHROPIC_API_KEY'\"\n  }]\n}\n' > /root/.continue/config.json"
}